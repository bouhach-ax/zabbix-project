# =============================================================================
# ZabbixPilot — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs.
# !! Ne JAMAIS committer le fichier .env !!
# =============================================================================

# -----------------------------------------------------------------------------
# Base de données PostgreSQL
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://zabbixpilot:zabbixpilot_dev_pass@localhost:5432/zabbixpilot

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://:redis_dev_pass@localhost:6379

# -----------------------------------------------------------------------------
# Sécurité — JWT
# Générer avec : node -e "require('crypto').randomBytes(32).toString('hex')|pbcopy"
# -----------------------------------------------------------------------------
JWT_SECRET=<256-bit-random-hex-string>
JWT_REFRESH_SECRET=<256-bit-random-hex-string-DIFFERENT-from-JWT_SECRET>
# Durée d'expiration des access tokens (ex: 15m, 1h)
JWT_ACCESS_EXPIRES_IN=15m
# Durée d'expiration des refresh tokens (ex: 30d)
JWT_REFRESH_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# Sécurité — Chiffrement AES-256-GCM
# Utilisé pour chiffrer les tokens API Zabbix en base de données
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DOIT être exactement 64 caractères hexadécimaux (= 32 bytes)
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=<64-hex-chars-exactly>

# -----------------------------------------------------------------------------
# API Anthropic (optionnel — LLM pour synthèse SLA uniquement)
# Si absent, les rapports SLA sont générés sans synthèse IA
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# SMTP — Envoi d'emails (rapports SLA, notifications)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@zabbixpilot.com
SMTP_SECURE=false

# -----------------------------------------------------------------------------
# Serveur
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# BullMQ — Concurrence des jobs de provisioning
# -----------------------------------------------------------------------------
PROVISIONING_CONCURRENCY=10

# -----------------------------------------------------------------------------
# Optionnel — Ansible AWX
# Si configuré, le provisioning soumettra des jobs AWX
# -----------------------------------------------------------------------------
AWX_URL=
AWX_TOKEN=
AWX_ORG_ID=

# -----------------------------------------------------------------------------
# Optionnel — Intégrations ITSM
# -----------------------------------------------------------------------------
SERVICENOW_URL=
SERVICENOW_USER=
SERVICENOW_PASS=
JIRA_URL=
JIRA_TOKEN=

# -----------------------------------------------------------------------------
# Optionnel — Notifications Slack
# -----------------------------------------------------------------------------
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=

# -----------------------------------------------------------------------------
# Optionnel — Notifications Microsoft Teams
# -----------------------------------------------------------------------------
TEAMS_WEBHOOK_URL=
