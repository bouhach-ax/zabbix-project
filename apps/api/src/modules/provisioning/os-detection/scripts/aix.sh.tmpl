#!/bin/bash
# ZabbixPilot — IBM AIX Zabbix Agent Installation Script
# Generated by script-generator.ts — DO NOT EDIT MANUALLY
# Target: {{HOSTNAME}} ({{ZABBIX_SERVER}})
set -e

echo "=== ZabbixPilot Agent Installer — AIX ==="
echo "Host: {{HOSTNAME}}"
echo "Zabbix Server: {{ZABBIX_SERVER}}"

ZABBIX_VERSION="7.0"
AGENT_CONF="/etc/zabbix/zabbix_agentd.conf"

# Step 1: Download Zabbix Agent RPM for AIX
echo "[1/6] Downloading Zabbix Agent for AIX..."
mkdir -p /tmp/zabbix_install
cd /tmp/zabbix_install
# AIX uses the classic agent (not agent2) — RPM-based install
wget -q "https://repo.zabbix.com/zabbix/${ZABBIX_VERSION}/aix/7.2/ppc/zabbix-agent-${ZABBIX_VERSION}.0-1.aix7.2.ppc.rpm" -O zabbix-agent.rpm

# Step 2: Install Zabbix Agent
echo "[2/6] Installing zabbix-agent..."
rpm -Uvh zabbix-agent.rpm || true

# Step 3: Configure Zabbix Agent
echo "[3/6] Configuring zabbix_agentd.conf..."
if [ -f "$AGENT_CONF" ]; then
  cp "$AGENT_CONF" "${AGENT_CONF}.bak.$(date +%Y%m%d%H%M%S)"
fi

cat > "$AGENT_CONF" << 'AGENTCONF'
# Zabbix Agent Configuration — Generated by ZabbixPilot
PidFile=/var/run/zabbix/zabbix_agentd.pid
LogFile=/var/log/zabbix/zabbix_agentd.log
LogFileSize=5
Server={{ZABBIX_SERVER}}
ServerActive={{ZABBIX_ACTIVE}}
Hostname={{HOSTNAME}}
ListenPort={{AGENT_PORT}}
AllowKey=system.run[*]
Timeout=15
AGENTCONF

# Ensure directories exist
mkdir -p /var/run/zabbix /var/log/zabbix
chown zabbix:zabbix /var/run/zabbix /var/log/zabbix

# Step 4: Configure AIX network access
echo "[4/6] Configuring network access..."
echo "Note: Verify that port {{AGENT_PORT}}/tcp is open on this AIX host."

# Step 5: Start the agent via SRC (System Resource Controller)
echo "[5/6] Starting zabbix_agentd..."
# Create SRC subsystem entry if not present
lssrc -s zabbix_agentd >/dev/null 2>&1 || \
  mkssys -s zabbix_agentd -p /usr/sbin/zabbix_agentd -u 0 -S -n 15 -f 9
stopsrc -s zabbix_agentd 2>/dev/null || true
startsrc -s zabbix_agentd

# Enable at boot via /etc/inittab
grep -q "zabbix_agentd" /etc/inittab 2>/dev/null || \
  mkitab "zabbix_agentd:2:respawn:/usr/sbin/zabbix_agentd"

# Step 6: Validation
echo "[6/6] Validating installation..."
sleep 3
if lssrc -s zabbix_agentd | grep -q "active"; then
  echo "SUCCESS: zabbix_agentd is running."
  echo "Listening on port {{AGENT_PORT}}"
else
  echo "ERROR: zabbix_agentd failed to start."
  lssrc -s zabbix_agentd
  exit 1
fi

# Cleanup
rm -rf /tmp/zabbix_install

echo "=== ZabbixPilot Agent Installation Complete ==="
