#!/bin/bash
# ZabbixPilot — Debian Zabbix Agent 2 Installation Script
# Generated by script-generator.ts — DO NOT EDIT MANUALLY
# Target: {{HOSTNAME}} ({{ZABBIX_SERVER}})
set -euo pipefail

echo "=== ZabbixPilot Agent Installer — Debian ==="
echo "Host: {{HOSTNAME}}"
echo "Zabbix Server: {{ZABBIX_SERVER}}"

# Step 1: Add Zabbix repository
echo "[1/6] Adding Zabbix repository..."
DEBIAN_VERSION=$(cat /etc/debian_version | cut -d. -f1)
wget -q "https://repo.zabbix.com/zabbix/7.0/debian/pool/main/z/zabbix-release/zabbix-release_latest_7.0+debian${DEBIAN_VERSION}_all.deb" -O /tmp/zabbix-release.deb
dpkg -i /tmp/zabbix-release.deb
apt-get update

# Step 2: Install Zabbix Agent 2
echo "[2/6] Installing zabbix-agent2..."
apt-get install -y zabbix-agent2 zabbix-agent2-plugin-*

# Step 3: Configure Zabbix Agent 2
echo "[3/6] Configuring zabbix_agent2.conf..."
CONF_FILE="/etc/zabbix/zabbix_agent2.conf"
cp "$CONF_FILE" "${CONF_FILE}.bak.$(date +%Y%m%d%H%M%S)"

sed -i "s/^Server=.*/Server={{ZABBIX_SERVER}}/" "$CONF_FILE"
sed -i "s/^ServerActive=.*/ServerActive={{ZABBIX_ACTIVE}}/" "$CONF_FILE"
sed -i "s/^Hostname=.*/Hostname={{HOSTNAME}}/" "$CONF_FILE"
sed -i "s/^# ListenPort=.*/ListenPort={{AGENT_PORT}}/" "$CONF_FILE"

# Enable system.run remote commands
if grep -q "^AllowKey=system.run" "$CONF_FILE"; then
  echo "AllowKey already configured."
else
  echo "AllowKey=system.run[*]" >> "$CONF_FILE"
fi

# Step 4: Configure firewall
echo "[4/6] Configuring firewall..."
if command -v ufw &>/dev/null; then
  ufw allow {{AGENT_PORT}}/tcp 2>/dev/null || true
fi

# Step 5: Enable and start service
echo "[5/6] Enabling and starting zabbix-agent2..."
systemctl enable zabbix-agent2
systemctl restart zabbix-agent2

# Step 6: Validation
echo "[6/6] Validating installation..."
sleep 2
if systemctl is-active --quiet zabbix-agent2; then
  echo "SUCCESS: zabbix-agent2 is running."
  echo "Agent version: $(zabbix_agent2 -V 2>/dev/null | head -1)"
  echo "Listening on port {{AGENT_PORT}}"
else
  echo "ERROR: zabbix-agent2 failed to start."
  systemctl status zabbix-agent2 --no-pager
  exit 1
fi

echo "=== ZabbixPilot Agent Installation Complete ==="
